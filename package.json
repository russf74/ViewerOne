{
  "name": "viewer-one",
  "version": "0.4.1",
  "description": "Live setlist display + MIDI control for Cubase",
  "author": "ViewerOne",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "launch": "npm run build && electron .",
    "preview": "electron-vite preview",
    "icons": "node scripts/make-ico.mjs",
    "dist": "npm run icons && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64",
    "dist:dir": "npm run icons && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "easymidi": "^3.1.0",
    "electron-store": "^9.0.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^10.1.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "png-to-ico": "^3.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.4.2",
    "vite": "^5.1.6"
  },
  "build": {
    "appId": "com.viewerone.app",
    "productName": "ViewerOne",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.ico",
    "files": [
      "**/*",
      "!src/**",
      "!scripts/**",
      "!electron.vite.config.ts",
      "!tsconfig.json",
      "!tsconfig.node.json",
      "!release/**",
      "!.git/**",
      "!**/*.md",
      "!node_modules/.cache/**"
    ],
    "asarUnpack": [
      "node_modules/easymidi/**",
      "node_modules/@serialport/**",
      "node_modules/serialport/**",
      "node_modules/**/*.node"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "ViewerOne",
      "signAndEditExecutable": false,
      "signDlls": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ViewerOne",
      "uninstallDisplayName": "ViewerOne",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "npmRebuild": false
  }
}
